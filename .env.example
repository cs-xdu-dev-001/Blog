# 管理端登录
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# SQLite数据库位置，不填则使用data/blog.sqlite
BLOG_DB_PATH=./data/blog.sqlite

# AI助手，可在管理端配置，也可用环境变量兜底
ASSISTANT_API_MODE=chat
ASSISTANT_BASE_URL=https://api.openai.com/v1
ASSISTANT_API_KEY=
ASSISTANT_MODEL=gpt-4.1-mini
ASSISTANT_PROXY_URL=
ASSISTANT_RATE_LIMIT_SALT=

---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dev Notes CMS | 主线" active="topics" dataAttr="data-topics-admin">
  <div slot="search" class="cms-admin-breadcrumb"><a href="/admin/posts">内容</a><span>/</span><a href="/admin/topics" aria-current="page">主线</a></div>
  <a slot="actions" href="/#topics" target="_blank" rel="noreferrer">预览主线</a>

  <section class="cms-index-shell">
    <header class="cms-index-head">
      <h1>主线</h1>
      <span class="cms-index-summary" data-topic-summary>正在读取</span>
    </header>

    <div class="cms-index-toolbar">
      <input type="search" placeholder="搜索主线、标签和详情" data-topic-search />
      <a class="cms-primary-action" href="/admin/topics/new">新增主线</a>
    </div>

    <div class="cms-index-list">
      <div class="cms-index-list-head"><span>主线</span><span>标签</span><span>强度</span><span>排序</span></div>
      <div data-topic-list></div>
    </div>
  </section>

  <script is:inline src="/admin-topics.js"></script>
</AdminLayout>

---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dev Notes CMS | 阅读书架" active="reading" dataAttr="data-reading-admin">
  <div slot="search" class="cms-admin-breadcrumb"><strong>内容</strong><span>/</span>阅读书架</div>
  <a slot="actions" href="/#reading" target="_blank" rel="noreferrer">预览书架</a>

  <section class="cms-index-shell">
    <header class="cms-index-head">
      <h1>阅读书架</h1>
      <span class="cms-index-summary" data-reading-stats>正在读取</span>
    </header>
    <div class="cms-index-toolbar">
      <input type="search" placeholder="搜索书名、作者、书评和摘句" data-reading-search />
      <div class="cms-filter-group" aria-label="书籍筛选">
        <button type="button" data-reading-filter="all" class="active">全部</button>
        <button type="button" data-reading-filter="reading">在读</button>
        <button type="button" data-reading-filter="read">已读</button>
        <button type="button" data-reading-filter="planned">待读</button>
        <button type="button" data-reading-filter="featured">精选</button>
      </div>
      <a class="cms-primary-action" href="/admin/reading/new">新增书籍</a>
    </div>
    <div class="cms-index-list">
      <div class="cms-index-list-head"><span>书籍</span><span>作者</span><span>状态</span><span></span></div>
      <div class="cms-index-error" data-reading-error hidden>
        <button class="cms-button" type="button" data-reading-retry>重新读取</button>
      </div>
      <div data-reading-list></div>
    </div>
  </section>
  <script is:inline src="/admin-reading.js"></script>
</AdminLayout>

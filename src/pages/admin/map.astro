---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dev Notes CMS | 地图校准" active="map" pageClass="map-admin-page" dataAttr="data-map-admin">
  <input slot="search" class="cms-search" type="search" value="Space地图校准" readonly />
  <a slot="actions" href="/#statistics" target="_blank" rel="noreferrer">预览首页</a>

  <Fragment slot="sidebar-actions">
    <span>地图工具</span>
    <button type="button" data-map-mode="heat">拖动热力点</button>
    <button type="button" data-map-mode="pin">拖动西安红点</button>
    <button type="button" data-map-mode="label">拖动地点胶囊</button>
  </Fragment>

  <div class="cms-hero">
    <div>
      <span>Travel Map</span>
      <h1>Space地图控制台</h1>
      <p>点位、当前城市和地图视觉都在这里调。保存后首页会直接读取这份配置。</p>
    </div>
    <strong data-map-state>READY</strong>
  </div>

  <div class="map-admin-stage">
    <div class="qzq-space-map map-editor-surface" data-map-surface>
      <div class="qzq-map-grid" aria-hidden="true"></div>
      <div class="qzq-map-tile-grid" aria-hidden="true" data-map-tiles>
        <img src="https://tile.openstreetmap.org/4/11/5.png" alt="" draggable="false" />
        <img src="https://tile.openstreetmap.org/4/12/5.png" alt="" draggable="false" />
        <img src="https://tile.openstreetmap.org/4/13/5.png" alt="" draggable="false" />
        <img src="https://tile.openstreetmap.org/4/11/6.png" alt="" draggable="false" />
        <img src="https://tile.openstreetmap.org/4/12/6.png" alt="" draggable="false" />
        <img src="https://tile.openstreetmap.org/4/13/6.png" alt="" draggable="false" />
        <img src="https://tile.openstreetmap.org/4/11/7.png" alt="" draggable="false" />
        <img src="https://tile.openstreetmap.org/4/12/7.png" alt="" draggable="false" />
        <img src="https://tile.openstreetmap.org/4/13/7.png" alt="" draggable="false" />
      </div>
      <div class="qzq-map-vignette" aria-hidden="true"></div>
      <div data-map-points></div>
      <span class="qzq-current-orbit qzq-current-orbit-a" data-current-orbit-a></span>
      <span class="qzq-current-orbit qzq-current-orbit-b" data-current-orbit-b></span>
      <span class="qzq-current-pin" data-current-pin title="Xi'an"></span>
      <span class="qzq-current-label" data-current-label>Xi'an, China&nbsp;&nbsp;中国西安</span>
    </div>
    <div class="map-rail-row" aria-label="地图横向偏移">
      <span>X</span>
      <input data-map-slider="map.x" type="range" min="-100" max="100" step="0.1" />
    </div>
    <div class="map-rail-column" aria-label="地图纵向偏移">
      <span>Y</span>
      <input data-map-slider="map.y" type="range" min="-100" max="100" step="0.1" />
    </div>
  </div>

  <aside slot="editor" class="cms-editor map-admin-panel">
    <span>Control</span>
    <p data-map-readout>默认拖动热力点。底图位置和视觉参数请用右侧控件调整。</p>

    <span>地图位置</span>
    <label>地图X偏移<input data-map-input="map.x" type="number" step="0.1" /></label>
    <label>地图Y偏移<input data-map-input="map.y" type="number" step="0.1" /></label>
    <label>地图缩放<input data-map-input="map.scale" type="range" step="0.01" min="0.6" max="2.2" /></label>

    <span>底图视觉</span>
    <label>亮度/曝光<input data-map-input="visual.brightness" type="range" step="0.01" min="0.5" max="1.8" /></label>
    <label>对比度<input data-map-input="visual.contrast" type="range" step="0.01" min="0.2" max="1.8" /></label>
    <label>饱和度<input data-map-input="visual.saturation" type="range" step="0.01" min="0.2" max="1.8" /></label>
    <label>图片透明度<input data-map-input="visual.opacity" type="range" step="0.01" min="0.2" max="1" /></label>
    <label>白色蒙版<input data-map-input="visual.overlay" type="range" step="0.01" min="0" max="0.85" /></label>

    <span>热力层</span>
    <label>热力点大小<input data-map-input="visual.heatSize" type="range" step="1" min="16" max="96" /></label>
    <label>热力点透明度<input data-map-input="visual.heatOpacity" type="range" step="0.01" min="0.1" max="1" /></label>
    <label>西安热力圈大小<input data-map-input="visual.currentHeatSize" type="range" step="1" min="80" max="320" /></label>
    <label>西安热力圈透明度<input data-map-input="visual.currentHeatOpacity" type="range" step="0.01" min="0" max="1" /></label>
    <label class="map-admin-toggle"><input data-map-checkbox="visual.showCityLabels" type="checkbox" />显示城市标签</label>

    <span>点位坐标</span>
    <label>西安X<input data-map-input="current.x" type="number" step="0.1" /></label>
    <label>西安Y<input data-map-input="current.y" type="number" step="0.1" /></label>
    <label>胶囊X<input data-map-input="label.x" type="number" step="0.1" /></label>
    <label>胶囊Y<input data-map-input="label.y" type="number" step="0.1" /></label>
    <button type="button" data-save-map>保存地图配置</button>
  </aside>

  <script is:inline src="/admin-map.js"></script>
</AdminLayout>

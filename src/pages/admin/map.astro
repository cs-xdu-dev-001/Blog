---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dev Notes CMS | 地图校准" active="map" pageClass="map-admin-page" dataAttr="data-map-admin">
  <div slot="search" class="cms-admin-breadcrumb"><strong>站点</strong><span>/</span>地图校准</div>
  <Fragment slot="actions">
    <a href="/#statistics" target="_blank" rel="noreferrer">预览首页</a>
    <button class="cms-primary-action" type="button" data-save-map>保存</button>
  </Fragment>

  <section class="cms-map-page">
    <header class="cms-index-head">
      <h1>地图校准</h1>
      <span class="cms-save-state" data-map-state>已就绪</span>
    </header>
    <div class="cms-index-toolbar cms-map-toolbar">
      <div class="cms-filter-group" aria-label="地图编辑模式">
        <button type="button" data-map-mode="heat" class="active">热力点</button>
        <button type="button" data-map-mode="pin">西安点</button>
        <button type="button" data-map-mode="label">地点标签</button>
      </div>
      <span class="cms-index-summary" data-map-readout>热力点模式</span>
    </div>

    <div class="cms-map-workspace">
      <div class="map-admin-stage">
        <div class="qzq-space-map map-editor-surface" data-map-surface>
          <div class="qzq-map-grid" aria-hidden="true"></div>
          <div class="qzq-map-tile-grid" aria-hidden="true" data-map-tiles>
            <img src="https://tile.openstreetmap.org/4/11/5.png" alt="" draggable="false" />
            <img src="https://tile.openstreetmap.org/4/12/5.png" alt="" draggable="false" />
            <img src="https://tile.openstreetmap.org/4/13/5.png" alt="" draggable="false" />
            <img src="https://tile.openstreetmap.org/4/11/6.png" alt="" draggable="false" />
            <img src="https://tile.openstreetmap.org/4/12/6.png" alt="" draggable="false" />
            <img src="https://tile.openstreetmap.org/4/13/6.png" alt="" draggable="false" />
            <img src="https://tile.openstreetmap.org/4/11/7.png" alt="" draggable="false" />
            <img src="https://tile.openstreetmap.org/4/12/7.png" alt="" draggable="false" />
            <img src="https://tile.openstreetmap.org/4/13/7.png" alt="" draggable="false" />
          </div>
          <div class="qzq-map-vignette" aria-hidden="true"></div>
          <div data-map-points></div>
          <span class="qzq-current-orbit qzq-current-orbit-a" data-current-orbit-a></span>
          <span class="qzq-current-orbit qzq-current-orbit-b" data-current-orbit-b></span>
          <span class="qzq-current-pin" data-current-pin title="Xi'an"></span>
          <span class="qzq-current-label" data-current-label>Xi'an, China&nbsp;&nbsp;中国西安</span>
        </div>
        <div class="map-rail-row" aria-label="地图横向偏移"><span>X</span><input data-map-slider="map.x" type="range" min="-100" max="100" step="0.1" /></div>
        <div class="map-rail-column" aria-label="地图纵向偏移"><span>Y</span><input data-map-slider="map.y" type="range" min="-100" max="100" step="0.1" /></div>
      </div>

      <aside class="cms-map-panel">
        <details open>
          <summary>地图位置</summary>
          <label class="cms-field"><span>X偏移</span><input data-map-input="map.x" type="number" step="0.1" /></label>
          <label class="cms-field"><span>Y偏移</span><input data-map-input="map.y" type="number" step="0.1" /></label>
          <label class="cms-field"><span>缩放</span><input data-map-input="map.scale" type="range" step="0.01" min="0.6" max="2.2" /></label>
        </details>
        <details open>
          <summary>底图视觉</summary>
          <label class="cms-field"><span>亮度</span><input data-map-input="visual.brightness" type="range" step="0.01" min="0.5" max="1.8" /></label>
          <label class="cms-field"><span>对比度</span><input data-map-input="visual.contrast" type="range" step="0.01" min="0.2" max="1.8" /></label>
          <label class="cms-field"><span>饱和度</span><input data-map-input="visual.saturation" type="range" step="0.01" min="0.2" max="1.8" /></label>
          <label class="cms-field"><span>透明度</span><input data-map-input="visual.opacity" type="range" step="0.01" min="0.2" max="1" /></label>
          <label class="cms-field"><span>白色蒙版</span><input data-map-input="visual.overlay" type="range" step="0.01" min="0" max="0.85" /></label>
        </details>
        <details>
          <summary>热力层</summary>
          <label class="cms-field"><span>热力点大小</span><input data-map-input="visual.heatSize" type="range" step="1" min="16" max="96" /></label>
          <label class="cms-field"><span>热力点透明度</span><input data-map-input="visual.heatOpacity" type="range" step="0.01" min="0.1" max="1" /></label>
          <label class="cms-field"><span>西安热力圈大小</span><input data-map-input="visual.currentHeatSize" type="range" step="1" min="80" max="320" /></label>
          <label class="cms-field"><span>西安热力圈透明度</span><input data-map-input="visual.currentHeatOpacity" type="range" step="0.01" min="0" max="1" /></label>
          <label class="cms-switch"><input data-map-checkbox="visual.showCityLabels" type="checkbox" />显示城市标签</label>
        </details>
        <details>
          <summary>点位坐标</summary>
          <label class="cms-field"><span>西安X</span><input data-map-input="current.x" type="number" step="0.1" /></label>
          <label class="cms-field"><span>西安Y</span><input data-map-input="current.y" type="number" step="0.1" /></label>
          <label class="cms-field"><span>标签X</span><input data-map-input="label.x" type="number" step="0.1" /></label>
          <label class="cms-field"><span>标签Y</span><input data-map-input="label.y" type="number" step="0.1" /></label>
        </details>
      </aside>
    </div>
  </section>
  <script is:inline src="/admin-map.js"></script>
</AdminLayout>

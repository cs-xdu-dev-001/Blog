---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dev Notes CMS | 笔记" active="posts" dataAttr="data-posts-admin">
  <div slot="search" class="cms-admin-breadcrumb"><a href="/admin/posts">内容</a><span>/</span><a href="/admin/posts" aria-current="page">笔记</a></div>
  <a slot="actions" href="/writing" target="_blank" rel="noreferrer">预览笔记</a>

  <section class="cms-index-shell">
    <header class="cms-index-head">
      <h1>笔记</h1>
      <span class="cms-index-summary" data-post-stats>正在读取</span>
    </header>

    <div class="cms-index-toolbar">
      <input type="search" placeholder="搜索标题、摘要和正文" data-post-search />
      <div class="cms-filter-group" aria-label="发布状态">
        <button type="button" data-post-filter="all" class="active">全部</button>
        <button type="button" data-post-filter="published">已发布</button>
        <button type="button" data-post-filter="draft">草稿</button>
        <button type="button" data-post-filter="featured">精选</button>
      </div>
      <select data-post-kind-filter aria-label="内容类型">
        <option value="all">全部类型</option>
        <option value="technical">技术</option>
        <option value="reflection">随记</option>
      </select>
      <select data-post-topic-filter aria-label="所属主线">
        <option value="">全部主线</option>
      </select>
      <div class="cms-toolbar-actions">
        <button class="cms-button" type="button" data-create-post data-post-category="随记">新增随记</button>
        <button class="cms-primary-action" type="button" data-create-post data-post-category="Notes">新增笔记</button>
      </div>
    </div>

    <div class="cms-index-list">
      <div class="cms-index-list-head"><span>标题</span><span>分类</span><span>状态</span><span></span></div>
      <div data-post-list></div>
    </div>
    <span class="cms-save-state" data-post-save-state hidden></span>
  </section>

  <script is:inline src="/admin-posts.js"></script>
</AdminLayout>

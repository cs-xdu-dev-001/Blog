---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dev Notes CMS | 影像档案" active="watch" dataAttr="data-watch-admin">
  <div slot="search" class="cms-admin-breadcrumb"><strong>内容</strong><span>/</span>影像档案</div>
  <a slot="actions" href="/#watch" target="_blank" rel="noreferrer">预览影像</a>

  <section class="cms-index-shell">
    <header class="cms-index-head">
      <h1>影像档案</h1>
      <span class="cms-index-summary" data-watch-summary>正在读取</span>
    </header>
    <div class="cms-index-toolbar">
      <input type="search" placeholder="搜索片名、评论和佳句" data-watch-search />
      <div class="cms-filter-group" aria-label="影像筛选">
        <button type="button" data-filter="all" class="active">全部</button>
        <button type="button" data-filter="watching">在看</button>
        <button type="button" data-filter="watched">已看</button>
        <button type="button" data-filter="wanted">想看</button>
        <button type="button" data-filter="activity">观看近况</button>
        <button type="button" data-filter="featured">精选</button>
      </div>
      <a class="cms-primary-action" href="/admin/watch/new">新增影像</a>
    </div>
    <div class="cms-index-list">
      <div class="cms-index-list-head"><span>影像</span><span>类型</span><span>状态</span><span></span></div>
      <div data-watch-list></div>
    </div>
  </section>
  <script is:inline src="/admin-watch.js"></script>
</AdminLayout>

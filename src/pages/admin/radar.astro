---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dev Notes CMS | 统计标签" active="radar" dataAttr="data-radar-admin">
  <div slot="search" class="cms-admin-breadcrumb"><a href="/admin/site">站点</a><span>/</span><a href="/admin/radar" aria-current="page">统计标签</a></div>
  <a slot="actions" href="/#statistics" target="_blank" rel="noreferrer">预览统计</a>

  <section class="cms-index-shell">
    <header class="cms-index-head">
      <h1>统计标签</h1>
      <span class="cms-index-summary" data-radar-summary>正在读取</span>
    </header>
    <div class="cms-index-toolbar">
      <input type="search" placeholder="搜索标签" data-radar-search />
      <div class="cms-filter-group" aria-label="标签类型">
        <button type="button" data-filter="all" class="active">全部</button>
        <button type="button" data-filter="movie">影视</button>
        <button type="button" data-filter="code">技术</button>
      </div>
      <button class="cms-primary-action" type="button" data-create-radar>新增标签</button>
    </div>
    <div class="cms-index-list">
      <div class="cms-index-list-head"><span>标签</span><span>类型</span><span>权重</span><span></span></div>
      <div data-radar-list></div>
    </div>
  </section>

  <dialog class="cms-drawer" data-radar-drawer>
    <header><h2 data-radar-drawer-title>编辑标签</h2><button class="cms-button" type="button" data-close-radar aria-label="关闭">关闭</button></header>
    <div class="cms-drawer-body"><form class="cms-editor-form" id="radar-editor-form" data-radar-form></form></div>
    <footer>
      <button class="cms-danger-action" type="button" data-delete-radar hidden>删除</button>
      <button class="cms-primary-action" type="submit" form="radar-editor-form">保存</button>
    </footer>
  </dialog>
  <script is:inline src="/admin-radar.js"></script>
</AdminLayout>

---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { requireAdmin } from '../../../../lib/server/auth.mjs';
import {
  getLockedNoteCookieName,
  readLockedNoteKeyFromCookie,
} from '../../../../lib/server/lockedNoteCrypto.mjs';
import { postRepository } from '../../../../lib/server/postRepository.mjs';
import { siteConfigRepository } from '../../../../lib/server/siteConfigRepository.mjs';

if (!requireAdmin(Astro)) {
  return Astro.redirect('/admin/login');
}

const id = Number(Astro.params.id);
const unlockKey = readLockedNoteKeyFromCookie(Astro.cookies.get(getLockedNoteCookieName())?.value);
let post = null;
if (Number.isFinite(id)) {
  try {
    post = postRepository.get(id, { unlockKey });
  } catch {
    Astro.cookies.delete(getLockedNoteCookieName(), { path: '/' });
    post = postRepository.get(id);
  }
}

if (!post) {
  return Astro.redirect('/admin/posts');
}

const postJson = JSON.stringify(post).replaceAll('<', '\\u003c');
const topicCards = (siteConfigRepository.getSiteConfig().topics?.cards || [])
  .filter((card) => card.slug && card.title);
const selectedTopicSlugs = new Set(post.topicSlugs || []);
const tagOptions = Array.from(new Set([
  ...(postRepository.listTags?.() || []),
  ...(post.tags || []),
])).filter(Boolean).sort((a, b) => a.localeCompare(b, 'zh-CN'));
const tagOptionsJson = JSON.stringify(tagOptions).replaceAll('<', '\\u003c');
const categoryOptions = Array.from(new Set([
  post.category,
  ...postRepository.list({ filter: 'all' }).items.map((item) => item.category),
  'AI Knowledge',
  'Frontend',
  'Automation',
  'Notes',
  'Reading',
  'Cinema',
  '随记',
].filter(Boolean))).sort((a, b) => a.localeCompare(b));
---

<BaseLayout title={`Dev Notes CMS | ${post.title}`} chrome={false} shell={false} assistant={false}>
  <main class="post-editor-page" data-post-editor-page>
    <header class="post-editor-topbar">
      <a class="post-editor-back" href="/admin/posts">← 返回笔记列表</a>
      <div class="post-editor-status">
        <span data-editor-status>READY</span>
      </div>
      <div class="post-editor-actions">
        <button type="button" data-preview-link>前台预览</button>
        <button type="button" class="danger" data-delete-post>删除</button>
        <button type="button" class="primary" data-save-post>保存</button>
        <button
          class="cms-theme-toggle post-editor-theme-toggle"
          type="button"
          data-admin-theme-toggle
          aria-label="切换管理端主题"
          title="切换管理端主题"
        >
          <svg class="cms-theme-icon cms-theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42"></path>
          </svg>
          <svg class="cms-theme-icon cms-theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"></path>
          </svg>
        </button>
      </div>
    </header>

    <section class="post-editor-shell is-edit" data-editor-shell>
      <form class="post-editor-meta" data-post-form>
        <div class="post-editor-meta-grid">
          <section class="post-editor-content-meta">
            <input class="post-title-input" name="title" value={post.title} required aria-label="标题" />
            <label class="post-description-field">
              <span>摘要</span>
              <textarea class="post-description-input" name="description" rows="2" placeholder="写一句前台可见的简介">{post.description || ''}</textarea>
            </label>
            <div class="post-tag-picker" data-tag-picker>
              <span class="post-tag-label">标签</span>
              <div class="post-tag-combobox">
                <div class="post-tag-summary" role="button" tabindex="0" data-tag-summary aria-expanded="false">选择标签</div>
                <div class="post-tag-popover" data-tag-popover hidden>
                  <div class="post-tag-input-row">
                    <input type="text" data-tag-input placeholder="新建或筛选标签" autocomplete="off" />
                    <button type="button" data-tag-add>新增</button>
                  </div>
                  <div class="post-tag-options" data-tag-options></div>
                </div>
              </div>
              <div data-tag-hidden></div>
            </div>
            <fieldset class="post-topic-picker">
              <legend>
                <span>关联主线</span>
                <a href="/admin/topics" target="_blank" rel="noreferrer">管理/新增主线</a>
              </legend>
              {topicCards.length > 0 ? (
                <div>
                  {topicCards.map((card) => (
                    <label>
                      <input type="checkbox" name="topicSlugs" value={card.slug} checked={selectedTopicSlugs.has(card.slug)} />
                      <span>{card.title}</span>
                    </label>
                  ))}
                </div>
              ) : (
                <div class="post-topic-empty">
                  <a href="/admin/topics" target="_blank" rel="noreferrer">新增第一条主线</a>
                </div>
              )}
            </fieldset>
          </section>

          <aside class="post-editor-properties" aria-label="笔记属性">
            <div class="post-meta-property-list">
              <label class="post-property post-property-slug">
                <span>URL别名</span>
                <div>
                  <input name="slug" value={post.slug} readonly data-slug-input />
                  <button type="button" data-regenerate-slug>重建</button>
                </div>
              </label>
              <label class="post-property">
                <span>分类</span>
                <select name="category">
                  {categoryOptions.map((category) => (
                    <option value={category} selected={category === post.category}>{category}</option>
                  ))}
                </select>
              </label>
              <label class="post-property">
                <span>日期</span>
                <input name="date" type="date" value={post.date} />
              </label>
              <label class="post-editor-check"><span>发布</span><input type="checkbox" name="published" checked={Boolean(post.published)} /></label>
              <label class="post-editor-check"><span>重点</span><input type="checkbox" name="featured" checked={Boolean(post.featured)} /></label>
              <div class="post-lock-property" data-lock-property>
                <span>访问权限</span>
                <label>
                  <input type="radio" name="visibility" value="public" checked={!post.locked} />
                  <b>公开</b>
                </label>
                <label>
                  <input type="radio" name="visibility" value="locked" checked={post.locked} />
                  <b>加密</b>
                </label>
                <input
                  type="password"
                  name="lockedNoteKey"
                  data-locked-note-key
                  autocomplete="new-password"
                  placeholder={post.locked ? '输入密钥' : '设置密钥'}
                />
                {post.locked && !post.lockedContentUnlocked && (
                  <button type="button" data-unlock-locked-post>解锁编辑</button>
                )}
                <em data-locked-note-status>{post.lockedContentUnlocked ? '已解锁' : ''}</em>
              </div>
            </div>
          </aside>
        </div>
      </form>

      <div class="post-editor-modebar" role="tablist" aria-label="编辑模式">
        <button type="button" class="active" data-editor-mode="edit">编辑</button>
        <button type="button" data-editor-mode="preview">预览</button>
        <button type="button" data-editor-mode="split">分屏</button>
      </div>

      <section class="post-editor-main">
        <section class="post-editor-pane post-editor-write post-editor-wysiwyg">
          <textarea class="post-editor-textarea" name="body" hidden data-markdown-input>{post.body || ''}</textarea>
          <div class="post-editor-milkdown" data-milkdown-editor></div>
        </section>

        <article class="post-editor-pane post-editor-preview article-prose" data-markdown-preview></article>
      </section>
    </section>

    <script type="application/json" id="post-editor-data" set:html={postJson}></script>
    <script type="application/json" id="post-tag-options-data" set:html={tagOptionsJson}></script>
    <script is:inline src="/admin-post-editor.js"></script>
    <script>
      import '../../../../scripts/admin-post-milkdown.js';
    </script>
  </main>
</BaseLayout>

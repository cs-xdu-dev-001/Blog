---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dev Notes CMS | 站点信息" active="site" dataAttr="data-site-admin">
  <div slot="search" class="cms-admin-breadcrumb"><strong>站点</strong><span>/</span>站点信息</div>
  <Fragment slot="actions"><a href="/" target="_blank" rel="noreferrer">预览首页</a><button class="cms-primary-action" type="submit" form="site-settings-form">保存</button></Fragment>
  <section class="cms-settings-page" data-site-section="site">
    <header><h1>站点信息</h1><span class="cms-save-state" data-save-state>正在读取</span></header>
    <nav class="cms-settings-tabs"><a class="active" href="/admin/site">站点信息</a><a href="/admin/home">首页模块</a><a href="/admin/assistant">AI助手</a><a href="/admin/about">关于</a></nav>
    <form id="site-settings-form" class="cms-settings-form" data-site-form>
      <section class="cms-settings-section">
        <h2>基础信息</h2>
        <div class="cms-settings-grid">
          <label class="cms-setting-field"><span>站点名</span><input name="brandName" /></label>
          <label class="cms-setting-field"><span>浏览器标题</span><input name="pageTitle" /></label>
          <label class="cms-setting-field full"><span>页面描述</span><textarea name="pageDescription"></textarea></label>
        </div>
      </section>
      <section class="cms-settings-section">
        <h2>社交链接</h2>
        <div class="cms-settings-grid">
          <label class="cms-setting-field"><span>GitHub</span><input name="social.github" type="url" /></label>
          <label class="cms-setting-field"><span>B站</span><input name="social.bilibili" type="url" /></label>
          <label class="cms-setting-field"><span>QQ号</span><input name="social.qq" /></label>
          <label class="cms-setting-field"><span>监控仪表盘</span><input name="social.monitor" type="url" /></label>
          <label class="cms-setting-field full"><span>AI站点</span><input name="social.ai" type="url" /></label>
        </div>
      </section>
    </form>
  </section>
  <script is:inline src="/admin-site.js"></script>
</AdminLayout>

---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dev Notes CMS | 新增主线" active="topics" dataAttr="data-topic-create-page">
  <div slot="search" class="cms-admin-breadcrumb"><a href="/admin/topics">主线</a><span>/</span>新增</div>

  <section class="cms-editor-page" data-topic-create-page>
    <header class="cms-editor-topbar">
      <h1>新增主线</h1>
      <div class="cms-editor-actions">
        <a class="cms-button" href="/admin/topics">取消</a>
        <button class="cms-primary-action" type="submit" form="topic-editor-form">创建</button>
      </div>
    </header>
    <form id="topic-editor-form" class="cms-editor-form" data-topic-editor-form>
      <div class="cms-field-grid">
        <label class="cms-field"><span>名称</span><input name="title" required autofocus /></label>
        <label class="cms-field"><span>Slug</span><input name="slug" placeholder="留空则自动生成" /></label>
        <label class="cms-field"><span>标签</span><input name="meta" placeholder="RAG / Agent / AI" /></label>
        <label class="cms-field"><span>强度</span><input name="level" type="number" min="1" max="8" value="5" /></label>
        <label class="cms-field full"><span>详情</span><textarea name="text" class="cms-long-text"></textarea></label>
      </div>
      <span class="cms-save-state" data-topic-editor-state></span>
    </form>
  </section>
  <script type="application/json" id="topic-editor-data">{"mode":"create"}</script>
  <script is:inline src="/admin-topic-editor.js"></script>
</AdminLayout>

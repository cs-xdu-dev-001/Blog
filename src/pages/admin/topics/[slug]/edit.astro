---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../../../lib/server/auth.mjs';
import { siteConfigRepository } from '../../../../lib/server/siteConfigRepository.mjs';

if (!requireAdmin(Astro)) return Astro.redirect('/admin/login');
const slug = String(Astro.params.slug || '');
const topic = siteConfigRepository.listTopics().find((item) => item.slug === slug);
if (!topic) return Astro.redirect('/admin/topics');
const topicJson = JSON.stringify({ mode: 'edit', item: topic }).replaceAll('<', '\\u003c');
---

<AdminLayout title={`Dev Notes CMS | ${topic.title}`} active="topics" dataAttr="data-topic-editor-page">
  <div slot="search" class="cms-admin-breadcrumb"><strong>主线</strong><span>/</span>{topic.title}</div>
  <a slot="actions" href={`/topics/${topic.slug}`} target="_blank" rel="noreferrer">前台查看</a>

  <section class="cms-editor-page" data-topic-editor-page>
    <header class="cms-editor-topbar">
      <h1>{topic.title}</h1>
      <div class="cms-editor-actions">
        <a class="cms-button" href="/admin/topics">返回</a>
        <button class="cms-danger-action" type="button" data-delete-topic>删除</button>
        <button class="cms-primary-action" type="submit" form="topic-editor-form">保存</button>
      </div>
    </header>

    <form id="topic-editor-form" class="cms-editor-form" data-topic-editor-form>
      <div class="cms-field-grid">
        <label class="cms-field"><span>名称</span><input name="title" required value={topic.title} /></label>
        <label class="cms-field"><span>Slug</span><input name="slug" value={topic.slug} /></label>
        <label class="cms-field"><span>标签</span><input name="meta" value={topic.meta} /></label>
        <label class="cms-field"><span>强度</span><input name="level" type="number" min="1" max="8" value={topic.level} /></label>
        <label class="cms-field full"><span>详情</span><textarea name="text" class="cms-long-text">{topic.text}</textarea></label>
      </div>
      <span class="cms-save-state" data-topic-editor-state></span>
    </form>

    <section class="cms-related-panel" data-topic-posts>
      <div class="cms-related-column">
        <header><span>已关联笔记</span><span data-linked-count></span></header>
        <div class="cms-related-list" data-linked-posts></div>
      </div>
      <div class="cms-related-column">
        <header><span>全部笔记</span><input type="search" placeholder="搜索笔记" data-available-search /></header>
        <div class="cms-related-list" data-available-posts></div>
      </div>
    </section>
  </section>
  <script type="application/json" id="topic-editor-data" set:html={topicJson}></script>
  <script is:inline src="/admin-topic-editor.js"></script>
</AdminLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { postRepository } from '../../lib/server/postRepository.mjs';
import { siteConfigRepository } from '../../lib/server/siteConfigRepository.mjs';

export const prerender = false;

postRepository.ensureSeededFromContent();
const slug = Astro.params.slug;
const siteConfig = siteConfigRepository.getSiteConfig();
const topic = (siteConfig.topics?.cards || []).find((card) => card.slug === slug);

if (!topic) {
  return Astro.redirect('/');
}

const posts = postRepository.list({ filter: 'published', topicSlug: slug, limit: 500 }).items;
const formatDate = (date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(date);
---

<BaseLayout title={`${topic.title} | Dev Notes`} description={topic.text || `${topic.title}主线笔记`}>
  <section class="topic-page">
    <header class="topic-page-hero">
      <a class="topic-page-back" href="/#topics">← 回到主线</a>
      <div class="topic-page-label">
        <span>{topic.meta}</span>
        <span>{posts.length}篇笔记</span>
      </div>
      <h1>{topic.title}</h1>
      {topic.text && <p>{topic.text}</p>}
    </header>

    {posts.length > 0 ? (
      <section class="topic-page-list" aria-label={`${topic.title}关联笔记`}>
        {posts.map((post, index) => (
          <a class="topic-page-row" href={`/posts/${post.slug}`}>
            <span class="topic-page-number">{String(index + 1).padStart(2, '0')}</span>
            <span class="topic-page-date">{formatDate(post.data.date)}</span>
            <span class="topic-page-category">{post.data.category}</span>
            <strong>{post.data.title}</strong>
            <span class="topic-page-summary">{post.data.description}</span>
          </a>
        ))}
      </section>
    ) : (
      <section class="topic-page-empty">
        <strong>这条主线还没有关联笔记。</strong>
        <a href="/admin/posts">去管理端关联</a>
      </section>
    )}
  </section>
</BaseLayout>

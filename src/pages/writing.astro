---
import BaseLayout from '../layouts/BaseLayout.astro';
import { postRepository } from '../lib/server/postRepository.mjs';

postRepository.ensureSeededFromContent();
const posts = postRepository.list({ filter: 'published', limit: 500 }).items;

const formatDate = (date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(date);
---

<BaseLayout title="近期笔记 | Dev Notes" description="全部笔记索引。">
  <header class="writing-hero">
    <div class="writing-heading">
      <h1>近期笔记</h1>
      <span>{posts.length}篇笔记</span>
    </div>
    <p>写下做过的东西，免得下次再从头找。</p>
  </header>

  <div class="writing-index-head">
    <strong>全部笔记</strong>
    <span>{String(posts.length).padStart(2, '0')}</span>
  </div>

  <section class="writing-list" aria-label="全部笔记">
    {posts.map((post, index) => (
      <a class="writing-row" href={`/posts/${post.slug}`} style={`--row-index: ${index};`}>
        <span class="writing-row-number">{String(index + 1).padStart(2, '0')}</span>
        <span class="writing-row-main">
          <strong>{post.data.title}</strong>
          {post.data.description && <span>{post.data.description}</span>}
        </span>
        <span class="writing-row-meta">
          <b>{formatDate(post.data.date)}</b>
          <i>{post.data.category}</i>
        </span>
        <span class="writing-row-arrow" aria-hidden="true">↗</span>
      </a>
    ))}
  </section>
</BaseLayout>

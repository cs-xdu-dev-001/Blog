---
import BaseLayout from '../layouts/BaseLayout.astro';
import { postRepository } from '../lib/server/postRepository.mjs';

postRepository.ensureSeededFromContent();
const posts = postRepository.list({ filter: 'published', limit: 500 }).items;

const formatDate = (date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(date);
---

<BaseLayout title="近期笔记 | Dev Notes" description="全部笔记索引。">
  <section class="writing-hero">
    <div class="writing-hero-label">
      <span>索引</span>
      <span>{posts.length}篇笔记</span>
    </div>
    <div>
      <h1>近期笔记</h1>
      <p>
        按时间整理的技术实践笔记。内容集中在部署、自动化、AI工具链、前端视觉和个人知识系统。
      </p>
    </div>
  </section>

  <section class="writing-list" aria-label="全部笔记">
    {posts.map((post, index) => (
      <a class="writing-row" href={`/posts/${post.slug}`}>
        <span class="writing-row-number">{String(index + 1).padStart(2, '0')}</span>
        <span class="writing-row-date">{formatDate(post.data.date)}</span>
        <span class="writing-row-category">{post.data.category}</span>
        <strong>{post.data.title}</strong>
        <span class="writing-row-summary">{post.data.description}</span>
      </a>
    ))}
  </section>
</BaseLayout>

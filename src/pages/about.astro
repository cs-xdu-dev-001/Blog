---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfigRepository } from '../lib/server/siteConfigRepository.mjs';

const siteConfig = siteConfigRepository.getSiteConfig();
const sections = Object.fromEntries(siteConfigRepository.listSections().map((section) => [section.key, section]));
const navSmall = (key, fallback) => {
  const value = sections[key]?.navSmall || fallback;
  return value === 'auto' ? fallback : value;
};
const aboutParagraphs = String(siteConfig.aboutBody || '').split(/\n{2,}/).filter(Boolean);
---

<BaseLayout
  title={`关于 | ${siteConfig.brandName}`}
  description={`关于${siteConfig.brandName}和站点作者。`}
  chrome={false}
  shell={false}
>
  <main class="qzq-home qzq-about-page">
    <nav class="qzq-nav" aria-label="Primary navigation">
      <a class="qzq-brand" href="/">{siteConfig.brandName}</a>
      <div class="qzq-nav-links">
        <a class="qzq-nav-item" href="/#topics"><span>{sections.topics?.navLabel || '主线'}</span><small>{navSmall('topics', '4')}</small></a>
        <a class="qzq-nav-item" href="/#notes"><span>{sections.notes?.navLabel || '笔记'}</span><small>{navSmall('notes', 'log')}</small></a>
        <a class="qzq-nav-item" href="/#watch"><span>{sections.watch?.navLabel || '影像'}</span><small>{navSmall('watch', 'film')}</small></a>
        <a class="qzq-nav-item" href="/#reading"><span>{sections.reading?.navLabel || '书架'}</span><small>{navSmall('reading', 'book')}</small></a>
        <a class="qzq-nav-item" href="/#statistics"><span>{sections.statistics?.navLabel || '统计'}</span><small>{navSmall('statistics', '∞')}</small></a>
        <a class="qzq-nav-item" href="/about"><span>{sections.about?.navLabel || '关于'}</span><small>{navSmall('about', 'me')}</small></a>
      </div>
      <div class="qzq-socials" aria-label="站点工具">
        <button type="button" class="global-search-trigger" data-global-search-open aria-label="打开全站搜索">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m16 16 5 5"></path>
          </svg>
        </button>
      </div>
    </nav>

    <section class="qzq-about-hero" aria-label="关于">
      <div class="qzq-about-kicker">About / {siteConfig.brandName}</div>
      <h1>{siteConfig.aboutTitle}</h1>
      {aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
    </section>

    <section class="qzq-about-grid" aria-label="个人信息">
      <article>
        <span>Now</span>
        <h2>正在关注</h2>
        <p>{siteConfig.aboutNow}</p>
      </article>
      <article>
        <span>Method</span>
        <h2>记录方式</h2>
        <p>{siteConfig.aboutMethod}</p>
      </article>
      <article>
        <span>Taste</span>
        <h2>审美偏好</h2>
        <p>{siteConfig.aboutTaste}</p>
      </article>
      <article>
        <span>Contact</span>
        <h2>联系我</h2>
        <p>GitHub：{siteConfig.social.github}。B站：{siteConfig.social.bilibili}。QQ：{siteConfig.social.qq}。</p>
      </article>
    </section>
  </main>
</BaseLayout>

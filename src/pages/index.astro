  <script>
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)');
    const cards = document.querySelectorAll('[data-tilt-card]:not([data-watch-detail])');
    const magneticLinks = document.querySelectorAll('.qzq-nav a, .qzq-feature-link');
    if (finePointer.matches && !prefersReducedMotion.matches) {
      cards.forEach((card) => {
        card.addEventListener('pointermove', (event) => {
          const rect = card.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - 0.5;
          const y = (event.clientY - rect.top) / rect.height - 0.5;
          card.style.setProperty('--tilt-x', `${y * -8}deg`);
          card.style.setProperty('--tilt-y', `${x * 8}deg`);
          card.style.setProperty('--shine-x', `${event.clientX - rect.left}px`);
          card.style.setProperty('--shine-y', `${event.clientY - rect.top}px`);
        });
        card.addEventListener('pointerleave', () => {
          card.style.setProperty('--tilt-x', '0deg');
          card.style.setProperty('--tilt-y', '0deg');
        });
      });
    }

    const watchActivity = document.querySelector('[data-watch-activity]');
    const watchActivityCards = [...document.querySelectorAll('[data-watch-activity-card]')];
    const clearWatchActivity = () => {
      watchActivity?.classList.remove('has-active');
      watchActivityCards.forEach((card) => {
        card.classList.remove('is-active');
        card.setAttribute('aria-expanded', 'false');
        card.querySelector('.qzq-watch-activity-detail')?.setAttribute('aria-hidden', 'true');
      });
    };
    const toggleWatchActivity = (card) => {
      const shouldOpen = !card.classList.contains('is-active');
      clearWatchActivity();
      if (!shouldOpen) return;
      card.classList.add('is-active');
      card.setAttribute('aria-expanded', 'true');
      card.querySelector('.qzq-watch-activity-detail')?.setAttribute('aria-hidden', 'false');
      watchActivity?.classList.add('has-active');
    };

    watchActivityCards.forEach((card) => {
      let pointerFrame = 0;
      if (finePointer.matches && !prefersReducedMotion.matches) {
        card.addEventListener('pointermove', (event) => {
          window.cancelAnimationFrame(pointerFrame);
          pointerFrame = window.requestAnimationFrame(() => {
            const rect = card.getBoundingClientRect();
            const x = (event.clientX - rect.left) / rect.width;
            const y = (event.clientY - rect.top) / rect.height;
            card.style.setProperty('--activity-pointer-x', `${(x * 100).toFixed(1)}%`);
            card.style.setProperty('--activity-pointer-y', `${(y * 100).toFixed(1)}%`);
            card.style.setProperty('--activity-tilt-x', `${((0.5 - y) * 3.2).toFixed(2)}deg`);
            card.style.setProperty('--activity-tilt-y', `${((x - 0.5) * 4.2).toFixed(2)}deg`);
          });
        });
        card.addEventListener('pointerleave', () => {
          window.cancelAnimationFrame(pointerFrame);
          card.style.setProperty('--activity-pointer-x', '50%');
          card.style.setProperty('--activity-pointer-y', '50%');
          card.style.setProperty('--activity-tilt-x', '0deg');
          card.style.setProperty('--activity-tilt-y', '0deg');
        });
      }
      card.addEventListener('click', () => toggleWatchActivity(card));
      card.addEventListener('keydown', (event) => {
        if (event.key !== ' ') return;
        event.preventDefault();
        toggleWatchActivity(card);
      });
    });

    const watchMarquee = document.querySelector('.qzq-watch-marquee');
    const watchSection = watchMarquee?.closest('.qzq-watch-section');
    const watchTracks = [...document.querySelectorAll('[data-random-watch-track]')];
    const watchCatalogElement = document.querySelector('[data-watch-catalog]');
    let watchCatalogs = [];
    try {
      watchCatalogs = JSON.parse(watchCatalogElement?.textContent || '[]');
    } catch {
      watchCatalogs = [];
    }

    const createWatchCard = (item, index) => {
      const card = document.createElement('article');
      card.className = `qzq-watch-card qzq-work-card qzq-work-${index % 4}`;
      card.tabIndex = 0;
      card.setAttribute('role', 'link');
      card.setAttribute('aria-label', `打开《${item.title || '未命名'}》影评`);
      card.setAttribute('data-tilt-card', '');
      card.setAttribute('data-watch-detail', '');
      card.setAttribute('data-href', item.href || '');

      if (item.image) {
        const image = document.createElement('img');
        image.className = 'qzq-work-image qzq-work-photo';
        image.src = item.imageSmall || item.image;
        if (item.imageSmall) {
          image.srcset = `${item.imageSmall} 480w, ${item.image} 960w`;
          image.sizes = '(max-width: 760px) 78vw, 360px';
        }
        image.alt = `${item.title || '影像'}配图`;
        image.width = 600;
        image.height = 394;
        image.loading = 'lazy';
        image.decoding = 'async';
        image.fetchPriority = 'low';
        card.append(image);
      } else {
        const image = document.createElement('div');
        image.className = 'qzq-work-image';
        image.setAttribute('aria-hidden', 'true');
        image.append(document.createElement('span'));
        card.append(image);
      }

      const head = document.createElement('div');
      head.className = 'qzq-watch-card-head';
      const meta = document.createElement('span');
      meta.textContent = `${item.status || ''} / ${item.type || ''}`;
      const title = document.createElement('strong');
      title.textContent = item.title || '未命名';
      head.append(meta, title);

      const line = document.createElement('p');
      line.textContent = item.lineSource
        ? item.line || ''
        : item.status === '想看' ? '已加入待看轨道' : '已收录到影像档案';
      const source = document.createElement('small');
      source.textContent = item.lineSource || (item.rating ? `${item.rating} 分` : '影像档案');
      card.append(head, line, source);
      return card;
    };

    const renderWatchBatch = (track, catalog, offset) => {
      if (!catalog?.length) return;
      const batchSize = Math.min(Number(track.dataset.watchBatchSize) || 12, catalog.length);
      const normalizedOffset = ((offset % catalog.length) + catalog.length) % catalog.length;
      const batch = Array.from(
        { length: batchSize },
        (_, index) => catalog[(normalizedOffset + index) % catalog.length],
      );
      const fragment = document.createDocumentFragment();
      [...batch, ...batch].forEach((item, index) => fragment.append(createWatchCard(item, index)));
      track.replaceChildren(fragment);
      track.dataset.watchOffset = String(normalizedOffset);
    };

    watchTracks.forEach((track) => {
      const rowIndex = Number(track.dataset.watchRow);
      const catalog = watchCatalogs[rowIndex] || [];
      const duration = Number.parseFloat(getComputedStyle(track).getPropertyValue('--watch-duration')) || 96;
      track.style.animationDelay = `${-(Math.random() * duration * 0.18)}s`;
      track.addEventListener('animationiteration', () => {
        const offset = Number(track.dataset.watchOffset) || 0;
        const batchSize = Number(track.dataset.watchBatchSize) || 12;
        renderWatchBatch(track, catalog, offset + batchSize);
      });
    });

    const watchCardFromEvent = (event) => {
      const card = event.target instanceof Element ? event.target.closest('[data-watch-detail]') : null;
      return card && watchSection?.contains(card) ? card : null;
    };
    const openWatchDetail = (card) => {
      const href = card?.getAttribute('data-href') || '';
      if (/^\/watch\/\d+$/.test(href)) window.location.href = href;
    };
    watchSection?.addEventListener('dblclick', (event) => openWatchDetail(watchCardFromEvent(event)));
    watchSection?.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter') return;
      const card = watchCardFromEvent(event);
      if (!card) return;
      event.preventDefault();
      openWatchDetail(card);
    });

    if (finePointer.matches && !prefersReducedMotion.matches) {
      watchMarquee?.addEventListener('pointermove', (event) => {
        const card = watchCardFromEvent(event);
        if (!card) return;
        const rect = card.getBoundingClientRect();
        const x = (event.clientX - rect.left) / rect.width - 0.5;
        const y = (event.clientY - rect.top) / rect.height - 0.5;
        card.style.setProperty('--tilt-x', `${y * -8}deg`);
        card.style.setProperty('--tilt-y', `${x * 8}deg`);
        card.style.setProperty('--shine-x', `${event.clientX - rect.left}px`);
        card.style.setProperty('--shine-y', `${event.clientY - rect.top}px`);
      });
      watchMarquee?.addEventListener('pointerout', (event) => {
        const card = watchCardFromEvent(event);
        if (!card || (event.relatedTarget instanceof Node && card.contains(event.relatedTarget))) return;
        card.style.setProperty('--tilt-x', '0deg');
        card.style.setProperty('--tilt-y', '0deg');
      });
    }

    let watchMarqueeVisible = false;
    const syncWatchMotion = () => {
      const paused = prefersReducedMotion.matches || document.hidden || !watchMarqueeVisible;
      watchMarquee?.classList.toggle('is-motion-paused', paused);
    };
    if ('IntersectionObserver' in window && watchMarquee) {
      const watchMotionObserver = new IntersectionObserver(([entry]) => {
        watchMarqueeVisible = Boolean(entry?.isIntersecting);
        syncWatchMotion();
      }, { threshold: 0.01, rootMargin: '12% 0px' });
      watchMotionObserver.observe(watchMarquee);
    } else {
      watchMarqueeVisible = true;
      syncWatchMotion();
    }
    document.addEventListener('visibilitychange', syncWatchMotion);
    prefersReducedMotion.addEventListener?.('change', syncWatchMotion);

    document.addEventListener('click', (event) => {
      if (!watchActivity?.contains(event.target)) clearWatchActivity();
    });

    if (finePointer.matches && !prefersReducedMotion.matches) {
      magneticLinks.forEach((link) => {
        link.addEventListener('pointermove', (event) => {
          const rect = link.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - 0.5;
          const y = (event.clientY - rect.top) / rect.height - 0.5;
          link.style.transform = `translate(${x * 8}px, ${y * 6}px)`;
        });
        link.addEventListener('pointerleave', () => {
          link.style.transform = 'translate(0, 0)';
        });
      });
    }

    const timeAreas = document.querySelectorAll('.qzq-time-area');
    timeAreas.forEach((area) => {
      area.addEventListener('pointerenter', () => {
        const group = area.closest('.qzq-time-areas');
        group?.classList.add('is-hovering');
        timeAreas.forEach((item) => item.classList.remove('is-active'));
        area.classList.add('is-active');
      });
      area.addEventListener('pointerleave', () => {
        const group = area.closest('.qzq-time-areas');
        group?.classList.remove('is-hovering');
        area.classList.remove('is-active');
      });
    });

    document.querySelectorAll('[data-radar-stage]').forEach((stage) => {
      const popover = stage.querySelector('[data-radar-popover]');
      const title = stage.querySelector('[data-radar-popover-title]');
      const count = stage.querySelector('[data-radar-popover-count]');
      const metric = stage.querySelector('[data-radar-popover-metric]');
      const showPopover = (point) => {
        const circle = point.querySelector('circle');
        if (!popover || !circle) return;
        const stageRect = stage.getBoundingClientRect();
        const circleRect = circle.getBoundingClientRect();
        const x = Math.min(Math.max(circleRect.left + circleRect.width / 2 - stageRect.left, 170), stageRect.width - 170);
        const y = circleRect.top + circleRect.height / 2 - stageRect.top;
        popover.style.setProperty('--popover-x', `${x}px`);
        popover.style.setProperty('--popover-y', `${y}px`);
        popover.classList.toggle('is-below', y < 128);
        title.textContent = point.getAttribute('data-radar-title') || '';
        count.textContent = point.getAttribute('data-radar-count') || '0';
        metric.textContent = stage.getAttribute('data-radar-metric') || '';
        popover.setAttribute('aria-hidden', 'false');
        popover.classList.add('is-visible');
      };
      const hidePopover = () => {
        popover?.setAttribute('aria-hidden', 'true');
        popover?.classList.remove('is-visible', 'is-below');
      };
      stage.querySelectorAll('[data-radar-point]').forEach((point) => {
        point.addEventListener('pointerenter', () => showPopover(point));
        point.addEventListener('focusin', () => showPopover(point));
        point.addEventListener('pointerleave', hidePopover);
        point.addEventListener('focusout', hidePopover);
      });
    });

    const enableMapEdit = new URLSearchParams(window.location.search).has('mapEdit');
    if (enableMapEdit) {
      document.querySelectorAll('.qzq-space-map').forEach((map) => {
        map.classList.add('is-editing');
        const panel = document.createElement('div');
        panel.className = 'qzq-map-edit-panel';
        panel.textContent = '閹锋牕濮╃痪銏㈠仯閹存牜鍎归崝娑氬仯';
        map.append(panel);

        const movePoint = (point, event) => {
          const rect = map.getBoundingClientRect();
          const x = Math.min(100, Math.max(0, ((event.clientX - rect.left) / rect.width) * 100));
          const y = Math.min(100, Math.max(0, ((event.clientY - rect.top) / rect.height) * 100));
          point.style.setProperty('--x', `${x.toFixed(2)}%`);
          point.style.setProperty('--y', `${y.toFixed(2)}%`);
          panel.textContent = `${point.getAttribute('title') || 'point'}: x ${x.toFixed(2)}%, y ${y.toFixed(2)}%`;
        };

        map.querySelectorAll('.qzq-travel-heat, .qzq-current-pin').forEach((point) => {
          point.addEventListener('pointerdown', (event) => {
            event.preventDefault();
            point.setPointerCapture(event.pointerId);
            point.classList.add('is-dragging');
            movePoint(point, event);
          });
          point.addEventListener('pointermove', (event) => {
            if (!point.classList.contains('is-dragging')) return;
            movePoint(point, event);
          });
          point.addEventListener('pointerup', (event) => {
            point.releasePointerCapture(event.pointerId);
            point.classList.remove('is-dragging');
          });
        });
      });
    }

    const formatCounter = (value) => new Intl.NumberFormat('zh-CN').format(value);
    const animateCounter = (counter) => {
      const target = Number(counter.getAttribute('data-count-to') || 0);
      if (prefersReducedMotion.matches) {
        counter.textContent = formatCounter(target);
        return;
      }
      let start = null;
      const scrambleUntil = 0.48;
      const tick = (time) => {
        start ??= time;
        const progress = Math.min((time - start) / 2600, 1);
        const eased = 1 - Math.pow(1 - progress, 2.4);
        const noise = progress < scrambleUntil ? Math.random() * target * (1 - progress) * 0.1 : 0;
        counter.textContent = formatCounter(Math.min(target, Math.round(target * eased + noise)));
        if (progress < 1) requestAnimationFrame(tick);
        else counter.textContent = formatCounter(target);
      };
      requestAnimationFrame(tick);
    };

    const counterGroup = document.querySelector('.qzq-story');
    if ('IntersectionObserver' in window && counterGroup) {
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting || counterGroup.dataset.countStarted) return;
          counterGroup.dataset.countStarted = 'true';
          counterGroup.querySelectorAll('[data-count-to]').forEach(animateCounter);
          counterObserver.unobserve(counterGroup);
        });
      }, { threshold: 0.45 });
      counterObserver.observe(counterGroup);
    } else {
      counterGroup?.querySelectorAll('[data-count-to]').forEach(animateCounter);
    }

    const revealSections = document.querySelectorAll('[data-reveal-section]');
    const revealSection = (section) => {
      section.classList.add('is-visible');
      const statisticsPanel = section.querySelector('[data-statistics-panel]');
      if (statisticsPanel) {
        statisticsPanel.classList.add('is-visible');
        if (!statisticsPanel.dataset.counting) {
          statisticsPanel.dataset.counting = 'true';
          statisticsPanel.querySelectorAll('[data-count-to]').forEach(animateCounter);
          window.setTimeout(() => {
            delete statisticsPanel.dataset.counting;
          }, 2800);
        }
      }
    };
    const concealSection = (section) => {
      section.classList.remove('is-visible');
      const statisticsPanel = section.querySelector('[data-statistics-panel]');
      statisticsPanel?.classList.remove('is-visible');
      if (watchActivity && section.contains(watchActivity)) clearWatchActivity();
    };
    if ('IntersectionObserver' in window && revealSections.length) {
      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            revealSection(entry.target);
          } else {
            concealSection(entry.target);
          }
        });
      }, { threshold: 0.01, rootMargin: '22% 0px -4% 0px' });
      revealSections.forEach((section) => {
        sectionObserver.observe(section);
        const rect = section.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          revealSection(section);
        }
      });
    } else {
      revealSections.forEach(revealSection);
    }

    const highlightMarks = document.querySelectorAll('[data-highlight-sweep]');
    const revealHighlight = (mark) => {
      mark.classList.add('is-visible');
    };
    if ('IntersectionObserver' in window) {
      const highlightObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          revealHighlight(entry.target);
          highlightObserver.unobserve(entry.target);
        });
      }, { threshold: 0.72, rootMargin: '0px 0px -8% 0px' });
      highlightMarks.forEach((mark) => highlightObserver.observe(mark));
    } else {
      highlightMarks.forEach(revealHighlight);
    }

    const orbitTokens = document.querySelectorAll('[data-orbit-token]');
    const orbitStage = document.querySelector('.qzq-orbit-stage');
    let orbitScale = 0.48;
    let orbitVisible = false;
    let orbitFrame = 0;
    const updateOrbitScale = () => {
      const stageWidth = orbitStage?.clientWidth || 760;
      orbitScale = Math.min(1, Math.max(0.48, stageWidth / 760));
    };
    const canAnimateOrbit = () => (
      Boolean(orbitStage)
      && orbitVisible
      && !document.hidden
      && !prefersReducedMotion.matches
    );
    const animateOrbit = (time) => {
      if (!canAnimateOrbit()) {
        orbitFrame = 0;
        return;
      }
      orbitTokens.forEach((token) => {
        const rx = Number(token.getAttribute('data-rx'));
        const ry = Number(token.getAttribute('data-ry'));
        const speed = Number(token.getAttribute('data-speed'));
        const phase = Number(token.getAttribute('data-phase'));
        const t = time / 1000 * speed + phase;
        token.style.setProperty('--orbit-x', `${Math.cos(t) * rx * orbitScale}px`);
        token.style.setProperty('--orbit-y', `${Math.sin(t) * ry * orbitScale}px`);
      });
      orbitFrame = window.requestAnimationFrame(animateOrbit);
    };
    const syncOrbitMotion = () => {
      const running = canAnimateOrbit();
      orbitStage?.classList.toggle('is-motion-paused', !running);
      if (running && !orbitFrame) orbitFrame = window.requestAnimationFrame(animateOrbit);
      if (!running && orbitFrame) {
        window.cancelAnimationFrame(orbitFrame);
        orbitFrame = 0;
      }
    };
    updateOrbitScale();
    if ('ResizeObserver' in window && orbitStage) {
      new ResizeObserver(updateOrbitScale).observe(orbitStage);
    }
    if ('IntersectionObserver' in window && orbitStage) {
      const orbitObserver = new IntersectionObserver(([entry]) => {
        orbitVisible = Boolean(entry?.isIntersecting);
        syncOrbitMotion();
      }, { threshold: 0.01, rootMargin: '12% 0px' });
      orbitObserver.observe(orbitStage);
    } else {
      orbitVisible = true;
      syncOrbitMotion();
    }
    document.addEventListener('visibilitychange', syncOrbitMotion);
    prefersReducedMotion.addEventListener?.('change', syncOrbitMotion);

    const readingShelf = document.querySelector('[data-reading-shelf]');
    let readingRotationPaused = false;
    let readingRotationHoldUntil = 0;

    const refreshBookIndexes = (row) => {
      row.querySelectorAll('[data-reading-book]').forEach((item, index) => {
        item.style.setProperty('--book-index', index);
      });
    };

    const activateBook = (book, options = {}) => {
      const row = book.parentElement;
      if (!row) return;
      row.querySelectorAll('[data-reading-book]').forEach((item) => item.classList.remove('is-active'));
      book.classList.add('is-active');
      if (options.focus !== false) book.focus({ preventScroll: true });
    };

    const rotateReadingShelf = () => {
      if (prefersReducedMotion.matches || readingRotationPaused || Date.now() < readingRotationHoldUntil) return;
      const row = readingShelf?.querySelector('.qzq-book-row');
      const books = row ? Array.from(row.querySelectorAll('[data-reading-book]')) : [];
      if (books.length < 2) return;
      const activeIndex = Math.max(0, books.findIndex((book) => book.classList.contains('is-active')));
      activateBook(books[(activeIndex + 1) % books.length], { focus: false });
    };

    readingShelf?.querySelectorAll('[data-reading-book]').forEach((book) => {
      book.addEventListener('click', () => {
        readingRotationHoldUntil = Date.now() + 18000;
        activateBook(book);
      });
      book.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          window.location.href = book.getAttribute('data-href');
        }
        if (event.key === ' ') {
          event.preventDefault();
          readingRotationHoldUntil = Date.now() + 18000;
          activateBook(book);
        }
      });
      book.addEventListener('dblclick', () => {
        window.location.href = book.getAttribute('data-href');
      });
    });

    if (readingShelf && !prefersReducedMotion.matches) {
      readingShelf.addEventListener('pointerenter', () => {
        readingRotationPaused = true;
      });
      readingShelf.addEventListener('pointerleave', () => {
        readingRotationPaused = false;
      });
      readingShelf.addEventListener('focusin', () => {
        readingRotationPaused = true;
      });
      readingShelf.addEventListener('focusout', () => {
        readingRotationPaused = false;
      });
      window.setInterval(rotateReadingShelf, 9000);
    }
  </script>
</BaseLayout>


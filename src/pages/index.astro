---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleIndex from '../components/ArticleIndex.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const featured = posts.filter((post) => post.data.featured).slice(0, 3);
const recent = posts.slice(0, 5);
---

<BaseLayout title="W. Notes · 极简技术博客" description="一个极简个人技术博客，记录部署、自动化和小型实践。">
  <section class="home-hero">
    <p class="home-kicker">
      Personal technical notes
    </p>
    <div class="home-intro">
      <h1>
        写下能复用的技术实践。
      </h1>
      <p>
        收集部署、自动化、爬虫和个人网站实践。内容保持短、清楚、可回看，界面不抢阅读。
      </p>
    </div>
  </section>

  <section class="home-section">
    <div class="home-section-label">
      <h2>Featured</h2>
    </div>
    <div class="home-section-body">
      <ArticleIndex posts={featured} />
    </div>
  </section>

  <section class="home-section">
    <div class="home-section-label">
      <h2>Recent</h2>
    </div>
    <div class="home-section-body">
      <ArticleIndex posts={recent} showDescriptions={false} compact />
      <a class="minimal-link view-all-link" href="/writing">
        View all writing
      </a>
    </div>
  </section>
</BaseLayout>

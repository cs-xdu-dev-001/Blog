---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWatchArchiveFromDb } from '../lib/server/watchArchiveView.mjs';
import { getAllReadingFromDb } from '../lib/server/readingArchiveView.mjs';
import { radarRepository } from '../lib/server/radarRepository.mjs';
import { mapRepository } from '../lib/server/mapRepository.mjs';
import { postRepository } from '../lib/server/postRepository.mjs';
import { siteConfigRepository } from '../lib/server/siteConfigRepository.mjs';

postRepository.ensureSeededFromContent();
const posts = postRepository.list({ filter: 'published', limit: 100 }).items;
const siteConfig = siteConfigRepository.getSiteConfig();
const sectionList = siteConfigRepository.listSections();
const sectionMap = Object.fromEntries(sectionList.map((section) => [section.key, section]));
const isSectionEnabled = (key) => sectionMap[key]?.enabled !== 0;
const section = (key, fallback) => ({
  title: sectionMap[key]?.title || fallback.title,
  navLabel: sectionMap[key]?.navLabel || fallback.navLabel,
  navSmall: sectionMap[key]?.navSmall || fallback.navSmall,
});
const navSmall = (key, fallback) => {
  const value = sectionMap[key]?.navSmall || fallback;
  if (value === 'auto') return fallback;
  return value;
};

const featured = posts.find((post) => post.featured) ?? posts[0];
const highlightPosts = posts.slice(0, 6);
const watchArchive = getWatchArchiveFromDb();
const WATCH_TRACK_BATCH_SIZE = 12;
const compactWatchItem = (item) => ({
  title: item.title,
  type: item.type,
  status: item.status,
  rating: item.rating,
  image: item.image,
  imageSmall: item.imageSmall,
  imageWidth: item.imageWidth,
  imageHeight: item.imageHeight,
  line: item.line,
  lineSource: item.lineSource,
  href: item.href,
});
const takeWatchBatch = (items, offset) => Array.from(
  { length: Math.min(WATCH_TRACK_BATCH_SIZE, items.length) },
  (_, index) => items[(offset + index) % items.length],
);
const watchTrackRows = watchArchive.rows.map((row, rowIndex) => {
  const catalog = row.items.map(compactWatchItem);
  const startIndex = catalog.length ? Math.floor(Math.random() * catalog.length) : 0;
  return {
    ...row,
    rowIndex,
    startIndex,
    catalog,
    initialItems: takeWatchBatch(catalog, startIndex),
  };
});
const watchCatalogJson = JSON.stringify(watchTrackRows.map((row) => row.catalog)).replace(/</g, '\\u003c');
const readingShelf = getAllReadingFromDb();
const travelMap = mapRepository.getConfig();
const travelMapStyle = [
  `--map-x: ${travelMap.map.x}%`,
  `--map-y: ${travelMap.map.y}%`,
  `--map-scale: ${travelMap.map.scale}`,
  `--map-saturation: ${travelMap.visual.saturation}`,
  `--map-contrast: ${travelMap.visual.contrast}`,
  `--map-brightness: ${travelMap.visual.brightness}`,
  `--map-opacity: ${travelMap.visual.opacity}`,
  `--map-overlay: ${travelMap.visual.overlay}`,
  `--heat-size: ${travelMap.visual.heatSize}px`,
  `--heat-opacity: ${travelMap.visual.heatOpacity}`,
  `--current-heat-size: ${travelMap.visual.currentHeatSize}px`,
  `--current-heat-opacity: ${travelMap.visual.currentHeatOpacity}`,
].join('; ');
const readingCarousel = [...readingShelf, ...readingShelf];
const readingTotal = readingShelf.length;
const watchStats = {
  total: watchArchive.stats.total ?? watchArchive.items.length,
  watched: watchArchive.stats.watched,
  wanted: watchArchive.stats.wanted,
  series: watchArchive.stats.series,
};
const archiveStats = [
  { value: posts.length, label: '公开笔记', note: 'Writing' },
  { value: watchStats.total, label: '影像作品', note: 'Cinema' },
  { value: watchStats.watched, label: '已看', note: 'Watched' },
  { value: watchStats.wanted, label: '待看', note: 'Queue' },
  { value: readingTotal, label: '阅读书籍', note: 'Reading' },
  { value: watchStats.series, label: '剧集', note: 'Series' },
];
const movieRadar = radarRepository.byScope('movie');
const codeRadar = radarRepository.byScope('code');
const radarAxes = (items) => {
  const cx = 280;
  const cy = 270;
  const outer = 182;
  const labelRadius = 242;
  return items.map((item, index) => {
    const angle = (-90 + (index * 360) / items.length) * Math.PI / 180;
    const outerX = cx + Math.cos(angle) * outer;
    const outerY = cy + Math.sin(angle) * outer;
    const rawLabelX = cx + Math.cos(angle) * labelRadius;
    const labelY = cy + Math.sin(angle) * labelRadius;
    const isLongLeftLabel = item.label === 'Science Fiction';
    const labelX = isLongLeftLabel ? Math.max(rawLabelX, 112) : rawLabelX;
    const valueRadius = outer * (item.value / 100);
    return {
      ...item,
      cx,
      cy,
      outerX,
      outerY,
      labelX,
      labelY,
      valueX: cx + Math.cos(angle) * valueRadius,
      valueY: cy + Math.sin(angle) * valueRadius,
      textAnchor: isLongLeftLabel ? 'middle' : Math.abs(labelX - cx) < 18 ? 'middle' : labelX > cx ? 'start' : 'end',
    };
  });
};
const radarPoints = (items) => radarAxes(items).map((item) => `${item.valueX},${item.valueY}`).join(' ');
const radarGrid = (items, level) => radarAxes(items).map((item) => {
  const x = item.cx + (item.outerX - item.cx) * level;
  const y = item.cy + (item.outerY - item.cy) * level;
  return `${x},${y}`;
}).join(' ');
const radarHitPoints = (items, item, index) => {
  const axes = radarAxes(items);
  const prev = axes[(index - 1 + axes.length) % axes.length];
  const next = axes[(index + 1) % axes.length];
  const midPrev = `${item.cx + (prev.outerX - item.cx) * 0.54},${item.cy + (prev.outerY - item.cy) * 0.54}`;
  const midNext = `${item.cx + (next.outerX - item.cx) * 0.54},${item.cy + (next.outerY - item.cy) * 0.54}`;
  return `${item.cx},${item.cy} ${midPrev} ${item.outerX},${item.outerY} ${midNext}`;
};
const topicCards = [
  {
    title: 'AI Knowledge',
    meta: 'Notion / RAG / Agent',
    text: '把Notion、Markdown、RAG和Agent放进同一条工作流，让笔记能被检索、引用，也能继续长成文章。',
    tone: 'magenta',
  },
  {
    title: 'Deployment',
    meta: 'Nginx / HTTPS / CI',
    text: '从域名、Nginx、HTTPS到自动部署，把上线过程中容易忘的命令和判断留下来。',
    tone: 'blue',
  },
  {
    title: 'Frontend',
    meta: 'Layout / UI / Screenshot',
    text: '用截图检查真实页面，盯住中文断行、移动端溢出、动效节奏和第一眼的视觉秩序。',
    tone: 'green',
  },
  {
    title: 'Automation',
    meta: 'Scripts / Workflow',
    text: '把重复的整理、构建、校验和发布动作收束成工具，让个人站点可以长期维护。',
    tone: 'orange',
  },
];

const orbitTags = [
  { label: 'CINEMA', rx: 386, ry: 186, speed: 0.27, phase: 5.28 },
  { label: 'RAG', rx: 270, ry: 270, speed: 0.48, phase: 1.42 },
  { label: 'UI', rx: 352, ry: 224, speed: 0.34, phase: 0.56 },
  { label: 'NOTION', rx: 228, ry: 214, speed: 0.56, phase: 3.78 },
  { label: 'AGENT', rx: 318, ry: 292, speed: 0.41, phase: 4.46 },
  { label: 'AI', rx: 252, ry: 178, speed: 0.52, phase: 2.84 },
  { label: 'FLOW', rx: 414, ry: 250, speed: 0.24, phase: 0.04 },
];
const configuredOrbitLabels = String(siteConfig.orbitTags || '')
  .split('/')
  .map((label) => label.trim())
  .filter(Boolean);
const orbitTagModels = (configuredOrbitLabels.length ? configuredOrbitLabels : orbitTags.map((tag) => tag.label))
  .map((label, index) => ({ ...orbitTags[index % orbitTags.length], label }));
---

<BaseLayout
  title={siteConfig.pageTitle}
  description={siteConfig.pageDescription}
  chrome={false}
  shell={false}
>
  <main class="qzq-home">
    <nav class="qzq-nav" aria-label="Primary navigation">
      <a class="qzq-brand" href="/">{siteConfig.brandName}</a>
      <div class="qzq-nav-links">
        {isSectionEnabled('topics') && <a class="qzq-nav-item" href="#topics"><span>{section('topics', { navLabel: '主线' }).navLabel}</span><small>{navSmall('topics', '4')}</small></a>}
        {isSectionEnabled('notes') && <a class="qzq-nav-item" href="#notes"><span>{section('notes', { navLabel: '笔记' }).navLabel}</span><small>{navSmall('notes', String(posts.length))}</small></a>}
        {isSectionEnabled('watch') && <a class="qzq-nav-item" href="#watch"><span>{section('watch', { navLabel: '影像' }).navLabel}</span><small>{navSmall('watch', String(watchStats.watched))}</small></a>}
        {isSectionEnabled('reading') && <a class="qzq-nav-item" href="#reading"><span>{section('reading', { navLabel: '书架' }).navLabel}</span><small>{navSmall('reading', String(readingTotal))}</small></a>}
        {isSectionEnabled('statistics') && <a class="qzq-nav-item" href="#statistics"><span>{section('statistics', { navLabel: '统计' }).navLabel}</span><small>{navSmall('statistics', '∞')}</small></a>}
        {isSectionEnabled('about') && <a class="qzq-nav-item" href="/about"><span>{section('about', { navLabel: '关于' }).navLabel}</span><small>{navSmall('about', 'me')}</small></a>}
      </div>
      <div class="qzq-socials" aria-label="Social links">
        <button type="button" class="global-search-trigger" data-global-search-open aria-label="打开全站搜索">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m16 16 5 5"></path>
          </svg>
        </button>
        <a href={siteConfig.social.github} target="_blank" rel="noreferrer" aria-label="GitHub">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.58 2 12.24c0 4.52 2.86 8.35 6.84 9.7.5.1.68-.22.68-.49v-1.88c-2.78.62-3.37-1.22-3.37-1.22-.46-1.18-1.11-1.5-1.11-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.35 9.35 0 0 1 12 6.95c.85 0 1.7.12 2.5.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.8-4.57 5.06.36.32.68.94.68 1.9v2.8c0 .27.18.59.69.49A10.2 10.2 0 0 0 22 12.24C22 6.58 17.52 2 12 2Z" />
          </svg>
        </a>
        <a href={siteConfig.social.bilibili} target="_blank" rel="noreferrer" aria-label="Bilibili">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8.06 4.1a.8.8 0 0 1 1.13-.03l2.08 1.96h1.46l2.08-1.96a.8.8 0 1 1 1.1 1.16l-.85.8h1.44A4.5 4.5 0 0 1 21 10.53v4.98A4.5 4.5 0 0 1 16.5 20h-9A4.5 4.5 0 0 1 3 15.5v-4.98a4.5 4.5 0 0 1 4.5-4.5h1.44l-.85-.8a.8.8 0 0 1-.03-1.13ZM7.5 8.02A2.5 2.5 0 0 0 5 10.52v4.98A2.5 2.5 0 0 0 7.5 18h9a2.5 2.5 0 0 0 2.5-2.5v-4.98a2.5 2.5 0 0 0-2.5-2.5h-9Zm1.8 3.05c.55 0 1 .45 1 1v1.36a1 1 0 1 1-2 0v-1.36c0-.55.45-1 1-1Zm5.4 0c.55 0 1 .45 1 1v1.36a1 1 0 1 1-2 0v-1.36c0-.55.45-1 1-1Z" />
          </svg>
        </a>
        {siteConfig.social.monitor && (
          <a
            class="qzq-monitor-link"
            href={siteConfig.social.monitor}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="监控仪表盘"
            title="监控仪表盘"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M2 12h4l3-8 6 16 3-8h4" />
            </svg>
          </a>
        )}
        <span class="qzq-qq-contact">
        <button type="button" aria-label="显示QQ号" aria-describedby="qq-number">
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path d="M6.048 3.323c.022.277-.13.523-.338.55-.21.026-.397-.176-.419-.453s.13-.523.338-.55c.21-.026.397.176.42.453Zm2.265-.24c-.603-.146-.894.256-.936.333-.027.048-.008.117.037.15.045.035.092.025.119-.003.361-.39.751-.172.829-.129l.011.007c.053.024.147.028.193-.098.023-.063.017-.11-.006-.142-.016-.023-.089-.08-.247-.118"/>
            <path d="M11.727 6.719c0-.022.01-.375.01-.557 0-3.07-1.45-6.156-5.015-6.156S1.708 3.092 1.708 6.162c0 .182.01.535.01.557l-.72 1.795a26 26 0 0 0-.534 1.508c-.68 2.187-.46 3.093-.292 3.113.36.044 1.401-1.647 1.401-1.647 0 .979.504 2.256 1.594 3.179-.408.126-.907.319-1.228.556-.29.213-.253.43-.201.518.228.386 3.92.246 4.985.126 1.065.12 4.756.26 4.984-.126.052-.088.088-.305-.2-.518-.322-.237-.822-.43-1.23-.557 1.09-.922 1.594-2.2 1.594-3.178 0 0 1.041 1.69 1.401 1.647.168-.02.388-.926-.292-3.113a26 26 0 0 0-.534-1.508l-.72-1.795ZM9.773 5.53a.1.1 0 0 1-.009.096c-.109.159-1.554.943-3.033.943h-.017c-1.48 0-2.925-.784-3.034-.943a.1.1 0 0 1-.018-.055q0-.022.01-.04c.13-.287 1.43-.606 3.042-.606h.017c1.611 0 2.912.319 3.042.605m-4.32-.989c-.483.022-.896-.529-.922-1.229s.344-1.286.828-1.308c.483-.022.896.529.922 1.23.027.7-.344 1.286-.827 1.307Zm2.538 0c-.484-.022-.854-.607-.828-1.308.027-.7.44-1.25.923-1.23.483.023.853.608.827 1.309-.026.7-.439 1.251-.922 1.23ZM2.928 8.99q.32.063.639.117v2.336s1.104.222 2.21.068V9.363q.49.027.937.023h.017c1.117.013 2.474-.136 3.786-.396.097.622.151 1.386.097 2.284-.146 2.45-1.6 3.99-3.846 4.012h-.091c-2.245-.023-3.7-1.562-3.846-4.011-.054-.9 0-1.663.097-2.285"/>
          </svg>
        </button>
        <span id="qq-number" class="qzq-qq-number">QQ {siteConfig.social.qq}</span>
        </span>
      </div>
    </nav>

    <section class="qzq-hero" aria-label="Intro">
      <div class="qzq-orbit-stage qzq-wordmark-stage is-motion-paused" data-tilt-card>
        <div class="qzq-orbit qzq-orbit-a"></div>
        <div class="qzq-orbit qzq-orbit-b"></div>
        <div class="qzq-orbit qzq-orbit-c"></div>
        {orbitTagModels.map((tag) => (
          <div
            class="qzq-token"
            data-orbit-token
            data-rx={tag.rx}
            data-ry={tag.ry}
            data-speed={tag.speed}
            data-phase={tag.phase}
          >
            {tag.label}
          </div>
        ))}

        <div class="qzq-wordmark-card">
          <div class="qzq-wordmark-topline">
            <span>{siteConfig.heroKicker}</span>
            <span>{siteConfig.heroMeta}</span>
          </div>
          <h1 aria-label="Dev Notes">
            <span data-text="Dev">Dev</span>
            <span data-text="Notes">Notes</span>
          </h1>
          <div class="qzq-wordmark-axis" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="qzq-wordmark-meta">
            <span>Public field notes</span>
            <span>Local AI stack</span>
            <span>UI verification</span>
            <span>Ship log</span>
          </div>
        </div>
      </div>

      <div class="qzq-story">
        <p>
          {siteConfig.heroLine}
        </p>
        <p class="qzq-data-line">
          {siteConfig.heroSubline}
        </p>
        <div class="qzq-stat-rhythm" aria-label="站点内容统计">
          <span><strong data-count-to={posts.length}>0</strong><em>公开笔记</em></span>
          <span><strong data-count-to={watchStats.total}>0</strong><em>影像作品</em></span>
          <span><strong data-count-to={watchStats.watched}>0</strong><em>已看</em></span>
          <span><strong data-count-to={watchStats.series}>0</strong><em>剧集</em></span>
          <span><strong data-count-to={readingTotal}>0</strong><em>阅读书籍</em></span>
          <span><strong data-count-to={watchStats.wanted}>0</strong><em>待看</em></span>
        </div>
        <p>
          <mark data-highlight-sweep>{siteConfig.heroHighlight}</mark>
        </p>
      </div>
    </section>

    {isSectionEnabled('topics') && <section id="topics" class="qzq-topic-section" aria-label="Topics" data-reveal-section>
      <div class="qzq-section-title">
        <h2>{section('topics', { title: '主线' }).title}</h2>
      </div>

      <div class="qzq-card-marquee" aria-label="主题频道">
        <div class="qzq-card-track">
          {[...topicCards, ...topicCards].map((card) => (
            <article class={`qzq-topic-card qzq-${card.tone}`} data-tilt-card>
              <div>
                <h3>{card.title}</h3>
                <span>{card.meta}</span>
              </div>
              <p>{card.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>}

    {isSectionEnabled('notes') && <section id="notes" class="qzq-notes-section" aria-label="近期笔记" data-reveal-section>
      <div class="qzq-section-title">
        <h2>{section('notes', { title: '近期笔记' }).title}</h2>
      </div>

      {featured && (
        <div class="qzq-notes-panel">
          <a class="qzq-note-feature" href={`/posts/${featured.slug}`} data-tilt-card>
            <span>{featured.data.category}</span>
            <h3>{featured.data.title}</h3>
            <p>{featured.data.description}</p>
            <small>{new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(featured.data.date)} · 重点笔记</small>
          </a>

          <div class="qzq-notes-list">
            {highlightPosts.filter((post) => post.slug !== featured.slug).slice(0, 5).map((post, index) => (
              <a class="qzq-note-row" href={`/posts/${post.slug}`}>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <strong>{post.data.title}</strong>
                  <p>{post.data.description}</p>
                </div>
                <em>{post.data.category}</em>
              </a>
            ))}
            <a class="qzq-notes-all" href="/writing">查看全部笔记</a>
          </div>
        </div>
      )}
    </section>}

    {isSectionEnabled('watch') && <section id="watch" class="qzq-watch-section" aria-label="影像档案" data-reveal-section>
      <div class="qzq-section-title qzq-watch-title">
        <h2>{section('watch', { title: '影像档案' }).title}</h2>
      </div>

      <div class="qzq-watch-summary">
        <div>
          <strong>{watchArchive.stats.watched}</strong>
          <span>已看</span>
        </div>
        <div>
          <strong>{watchArchive.stats.wanted}</strong>
          <span>想看</span>
        </div>
      </div>

      {watchArchive.activity && (
        <div class="qzq-watch-activity" data-watch-activity>
          <article
            class="qzq-watch-activity-card qzq-watch-activity-watching"
            style={watchArchive.activity.watching.image ? `--activity-image: url('${watchArchive.activity.watching.image}')` : undefined}
            tabindex="0"
            role="button"
            aria-expanded="false"
            aria-label={`查看《${watchArchive.activity.watching.title}》观看记录`}
            data-watch-activity-card
            data-watch-detail
            data-href={watchArchive.activity.watching.href}
          >
            <div class="qzq-watch-activity-copy">
              <span class="qzq-watch-activity-state"><i></i>近期在看</span>
              <h3>{watchArchive.activity.watching.title}</h3>
              <p>{watchArchive.activity.watching.type}</p>
            </div>
            {watchArchive.activity.watching.image && (
              <img
                class="qzq-watch-activity-poster"
                src={watchArchive.activity.watching.imageSmall || watchArchive.activity.watching.image}
                srcset={watchArchive.activity.watching.imageSmall ? `${watchArchive.activity.watching.imageSmall} 480w, ${watchArchive.activity.watching.image} 960w` : undefined}
                sizes="(max-width: 760px) 88vw, 460px"
                width={watchArchive.activity.watching.imageWidth || 960}
                height={watchArchive.activity.watching.imageHeight || 640}
                alt=""
                loading="lazy"
                decoding="async"
                data-depth-poster
              />
            )}
            <div class="qzq-watch-activity-detail" aria-hidden="true">
              <strong>观看记录</strong>
              <span>{watchArchive.activity.watching.progressText || '进度尚未填写'}</span>
            </div>
          </article>

          <article
            class="qzq-watch-activity-card qzq-watch-activity-finished"
            style={watchArchive.activity.finished.image ? `--activity-image: url('${watchArchive.activity.finished.image}')` : undefined}
            tabindex="0"
            role="button"
            aria-expanded="false"
            aria-label={`查看《${watchArchive.activity.finished.title}》观看记录`}
            data-watch-activity-card
            data-watch-detail
            data-href={watchArchive.activity.finished.href}
          >
            <div class="qzq-watch-activity-copy">
              <span class="qzq-watch-activity-state"><i></i>近期看完</span>
              <h3>{watchArchive.activity.finished.title}</h3>
              <p>{watchArchive.activity.finished.type}</p>
            </div>
            {watchArchive.activity.finished.image && (
              <img
                class="qzq-watch-activity-poster"
                src={watchArchive.activity.finished.imageSmall || watchArchive.activity.finished.image}
                srcset={watchArchive.activity.finished.imageSmall ? `${watchArchive.activity.finished.imageSmall} 480w, ${watchArchive.activity.finished.image} 960w` : undefined}
                sizes="(max-width: 760px) 88vw, 460px"
                width={watchArchive.activity.finished.imageWidth || 960}
                height={watchArchive.activity.finished.imageHeight || 640}
                alt=""
                loading="lazy"
                decoding="async"

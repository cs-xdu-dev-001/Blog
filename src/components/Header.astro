---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/writing', label: 'Writing' },
  { href: '/reading', label: 'Reading' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header minimal-grid items-start">
  <a href="/" class="minimal-link col-span-3 text-[#000000]" aria-label="Home">
    Dev Notes
  </a>
  <nav class="site-nav col-span-6 col-start-7 flex justify-between gap-6 md:justify-start md:gap-10" aria-label="Primary navigation">
    {navItems.map((item) => (
      <a class="minimal-link" href={item.href}>{item.label}</a>
    ))}
    <button type="button" class="global-search-trigger global-search-trigger-minimal" data-global-search-open aria-label="打开全站搜索">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m16 16 5 5"></path>
      </svg>
    </button>
  </nav>
</header>

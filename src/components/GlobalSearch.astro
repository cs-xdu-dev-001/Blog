<div class="global-search" data-global-search hidden>
  <button class="global-search-backdrop" type="button" data-global-search-close aria-label="关闭搜索"></button>
  <section class="global-search-panel" role="dialog" aria-modal="true" aria-label="全站搜索">
    <header class="global-search-query">
      <button class="global-search-mobile-back" type="button" data-global-search-back aria-label="返回搜索结果">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m14 6-6 6 6 6"></path>
        </svg>
      </button>
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m16 16 5 5"></path>
      </svg>
      <input
        type="search"
        maxlength="100"
        autocomplete="off"
        spellcheck="false"
        placeholder="搜索笔记、书籍、影像和标签"
        aria-label="搜索笔记、书籍、影像和标签"
        data-global-search-input
      />
      <button type="button" data-global-search-close aria-label="关闭搜索">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18"></path>
        </svg>
      </button>
    </header>
    <div class="global-search-layout">
      <div class="global-search-results" role="listbox" aria-label="搜索结果" data-global-search-results></div>
      <aside class="global-search-preview" aria-live="polite" data-global-search-preview></aside>
    </div>
  </section>
</div>

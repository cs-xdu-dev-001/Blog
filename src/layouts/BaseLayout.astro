---
import '../styles/global.css';
import GlobalSearch from '../components/GlobalSearch.astro';
import Header from '../components/Header.astro';
import MinimalFooter from '../components/MinimalFooter.astro';
import {
  DEFAULT_OG_IMAGE_PATH,
  absoluteSiteUrl,
} from '../lib/publicationMetadata.mjs';

const {
  title = 'Dev Notes',
  description = 'A minimal personal technical blog.',
  type = 'website',
  image = DEFAULT_OG_IMAGE_PATH,
  imageWidth = null,
  imageHeight = null,
  publishedTime = null,
  chrome = true,
  shell = true,
  assistant = true,
} = Astro.props;

const isAdminRoute = Astro.url.pathname.startsWith('/admin');
const canonicalUrl = absoluteSiteUrl(Astro.url.pathname);
const socialImageUrl = absoluteSiteUrl(image || DEFAULT_OG_IMAGE_PATH);
const usesDefaultSocialImage = !image || image === DEFAULT_OG_IMAGE_PATH;
const socialImageWidth = imageWidth || (usesDefaultSocialImage ? 1200 : null);
const socialImageHeight = imageHeight || (usesDefaultSocialImage ? 630 : null);

let assistantConfig = null;
if (assistant) {
  const { siteConfigRepository } = await import('../lib/server/siteConfigRepository.mjs');
  const siteConfig = siteConfigRepository.getSiteConfig();
  assistantConfig = siteConfig.assistant?.enabled === false ? null : {
    title: siteConfig.assistant?.title,
    placeholder: siteConfig.assistant?.placeholder,
    maxQuestionLength: siteConfig.assistant?.maxQuestionLength,
  };
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {isAdminRoute && (
      <script is:inline>
        (() => {
          const storageKey = 'dev-notes-admin-theme';
          let theme = '';
          try {
            theme = localStorage.getItem(storageKey) || '';
          } catch {}
          if (theme !== 'light' && theme !== 'dark') {
            theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.dataset.adminTheme = theme;
          document.documentElement.style.colorScheme = theme;
        })();
      </script>
    )}
    {isAdminRoute ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <>
        <link rel="canonical" href={canonicalUrl} />
        <link rel="alternate" type="application/rss+xml" title="Dev Notes RSS" href={absoluteSiteUrl('/rss.xml')} />
        <meta property="og:locale" content="zh_CN" />
        <meta property="og:site_name" content="Dev Notes" />
        <meta property="og:type" content={type} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={socialImageUrl} />
        {socialImageWidth && <meta property="og:image:width" content={String(socialImageWidth)} />}
        {socialImageHeight && <meta property="og:image:height" content={String(socialImageHeight)} />}
        <meta property="og:image:alt" content={`${title}分享封面`} />
        {type === 'article' && publishedTime && (
          <meta property="article:published_time" content={new Date(publishedTime).toISOString()} />
        )}
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={socialImageUrl} />
      </>
    )}
    <title>{title}</title>
  </head>
  <body>
    <a class="sr-only focus:not-sr-only focus:fixed focus:left-6 focus:top-6 focus:z-50 focus:bg-white focus:px-4 focus:py-3 focus:text-sm focus:text-black" href="#main-content">
      Skip to main content
    </a>
    <div class={shell ? 'minimal-shell' : undefined}>
      {chrome && <Header />}
      <main id="main-content">
        <slot />
      </main>
      {chrome && <MinimalFooter />}
    </div>
    {!isAdminRoute && <GlobalSearch />}
    {assistantConfig && (
      <div
        class="dn-assistant"
        data-assistant-root
      >
        <button class="dn-assistant-trigger" type="button" data-assistant-open aria-label="打开站内AI助手">
          <span>Ask</span>
          <i>AI</i>
        </button>
        <section class="dn-assistant-panel" data-assistant-panel aria-hidden="true" aria-label="站内AI助手">
          <div class="dn-assistant-head" data-assistant-drag-handle title="拖动窗口">
            <h2>{assistantConfig.title}</h2>
            <div class="dn-assistant-head-actions">
              <button class="dn-assistant-clear" type="button" data-assistant-clear aria-label="清空当前对话" disabled>清空</button>
              <button class="dn-assistant-close" type="button" data-assistant-close aria-label="关闭站内AI助手">×</button>
            </div>
          </div>
          <div class="dn-assistant-body"></div>
          <form class="dn-assistant-form" data-assistant-form>
            <textarea data-assistant-input rows="4" maxlength={assistantConfig.maxQuestionLength} placeholder={assistantConfig.placeholder}></textarea>
            <button type="submit" data-assistant-submit aria-label="发送消息">
              <svg data-assistant-send-icon viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h13M13 6l6 6-6 6" />
              </svg>
              <svg data-assistant-stop-icon viewBox="0 0 24 24" aria-hidden="true">
                <rect x="7" y="7" width="10" height="10" rx="1" />
              </svg>
            </button>
          </form>
        </section>
      </div>
    )}
    {assistantConfig && <script is:inline type="module" src="/assistant.js"></script>}
    {!isAdminRoute && <script is:inline type="module" src="/global-search.js"></script>}
    {isAdminRoute && (
      <script is:inline>
        (() => {
          const storageKey = 'dev-notes-admin-theme';
          const root = document.documentElement;
          const toggles = document.querySelectorAll('[data-admin-theme-toggle]');

          const syncToggles = () => {
            const isDark = root.dataset.adminTheme !== 'light';
            const label = isDark ? '切换到浅色模式' : '切换到深色模式';
            toggles.forEach((toggle) => {
              toggle.setAttribute('aria-label', label);
              toggle.setAttribute('title', label);
              toggle.setAttribute('aria-pressed', String(!isDark));
            });
          };

          toggles.forEach((toggle) => {
            toggle.addEventListener('click', () => {
              const theme = root.dataset.adminTheme === 'light' ? 'dark' : 'light';
              root.dataset.adminTheme = theme;
              root.style.colorScheme = theme;
              try {
                localStorage.setItem(storageKey, theme);
              } catch {}
              syncToggles();
            });
          });

          syncToggles();
        })();
      </script>
    )}
  </body>
</html>

---
import BaseLayout from './BaseLayout.astro';

const { title, description, date, category } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(date);
---

<BaseLayout title={`${title} · W. Notes`} description={description}>
  <article class="minimal-grid">
    <header class="col-span-8 col-start-3 mb-20">
      <a class="minimal-link mb-12 inline-block text-sm tracking-[0.03em] text-[#808080]" href="/writing">
        Back to writing
      </a>
      <p class="mb-8 text-xs tracking-[0.12em] text-[#999999]">
        {category} / {formattedDate}
      </p>
      <h1 class="max-w-[820px] text-balance text-[clamp(38px,7vw,72px)] font-light leading-[1.08] tracking-[-0.022em] text-[#000000]">
        {title}
      </h1>
      <p class="mt-10 max-w-[680px] text-lg leading-8 tracking-[0.02em] text-[#666666]">
        {description}
      </p>
    </header>
    <div class="article-prose col-span-7 col-start-3">
      <slot />
    </div>
  </article>
</BaseLayout>

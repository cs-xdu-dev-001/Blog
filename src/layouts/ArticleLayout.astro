---
import BaseLayout from './BaseLayout.astro';

const {
  title,
  description,
  date,
  category,
  readingTime = 1,
  headings = [],
  prevPost = null,
  nextPost = null,
} = Astro.props;
const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(date);
---

<BaseLayout
  title={`${title} | Dev Notes`}
  description={description}
  type="article"
  publishedTime={date}
>
  <article class="post-shell">
    <aside class="post-side" aria-label="文章信息">
      <a class="post-side-back" href="/writing">返回文章索引</a>
      <dl>
        <div>
          <dt>分类</dt>
          <dd>{category}</dd>
        </div>
        <div>
          <dt>日期</dt>
          <dd>{formattedDate}</dd>
        </div>
        <div>
          <dt>阅读</dt>
          <dd>{readingTime}分钟</dd>
        </div>
      </dl>
      {headings.length > 0 && (
        <nav class="post-toc" aria-label="文章目录">
          <span>目录</span>
          {headings.map((heading) => (
            <a href={`#${heading.slug}`}>{heading.text}</a>
          ))}
        </nav>
      )}
    </aside>

    <div class="post-paper">
      <header class="post-header">
        <h1>{title}</h1>
        <p>{description}</p>
      </header>

      <div class="post-body article-prose">
        <slot />
      </div>

      <footer class="post-footer">
        <p>写给未来会再查一遍的自己。</p>
        <div class="post-footer-links">
          <a href="/writing">文章索引</a>
          <a href="/">回到首页</a>
        </div>
        {(prevPost || nextPost) && (
          <div class="post-read-next" aria-label="继续阅读">
            {prevPost && (
              <a href={`/posts/${prevPost.slug}`}>
                <span>上一篇</span>
                <strong>{prevPost.data.title}</strong>
              </a>
            )}
            {nextPost && (
              <a href={`/posts/${nextPost.slug}`}>
                <span>下一篇</span>
                <strong>{nextPost.data.title}</strong>
              </a>
            )}
          </div>
        )}
      </footer>
    </div>
  </article>
</BaseLayout>
